{
  "name": "R Tidyverse",
  "image": "rocker/tidyverse:4.5.0",
  "customizations": {
    "vscode": {
      "extensions": [
        "REditorSupport.r",
        "RDebugger.r-debugger"
      ]
    }
  },
  "forwardPorts": [8787],
  "postStartCommand": "sudo rstudio-server start",
  "postCreateCommand": "R -e \"install.packages(c('patchwork', 'janitor', 'here', 'quarto', 'languageserver')); message('R is ready!')\"",
  "remoteUser": "rstudio"
}
